<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- DEBUG-ONLY overlay. Manifest-merged into debug builds only, never
         release. Enables cleartext HTTP so a debug build can reach a local
         dev server (e.g. http://10.0.2.2:8000, the emulator's alias for the
         host machine) — Android blocks cleartext by default from API 28.
         Release builds keep cleartext blocked, as they must (Golden Rule 1:
         the phone only ever talks to our HTTPS server in production). -->
    <application android:usesCleartextTraffic="true" />
</manifest>
