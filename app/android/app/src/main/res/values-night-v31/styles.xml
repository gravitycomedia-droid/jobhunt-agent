<?xml version="1.0" encoding="utf-8"?>
<!-- Dark-mode variant of the Android 12+ launch screen. Deliberately identical to
     values-v31: the brand fill should not change with the user's system theme, and
     the app's own SplashScreen renders on brand600 either way — so a dark launch
     screen would flash a different colour before handing off. -->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowSplashScreenBackground">@color/brand600</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
