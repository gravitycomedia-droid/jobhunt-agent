<?xml version="1.0" encoding="utf-8"?>
<!-- API 21+ variant of the native launch screen. Kept identical to the base
     drawable on purpose: the template used ?android:colorBackground here, which
     follows the system light/dark theme and so flashed white or black depending
     on the device. The brand fill should not depend on the user's theme. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/brand600" />

    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/ic_launcher_foreground" />
    </item>
</layer-list>
