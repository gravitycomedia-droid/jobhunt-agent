<?xml version="1.0" encoding="utf-8"?>
<!-- Native launch screen: what Android draws between process start and Flutter's
     first frame. Brand-filled with the mark centred, so it hands off seamlessly
     to SplashScreen, which shows the same mark on the same colour. The template
     shipped plain white, which flashed before Flutter took over. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/brand600" />

    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/ic_launcher_foreground" />
    </item>
</layer-list>
