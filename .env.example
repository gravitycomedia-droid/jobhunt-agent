# ============================================
# Job-Hunt Agent — environment template
# Copy to server/.env and fill in real values.
# NEVER commit .env — it's in .gitignore.
# All keys live SERVER-SIDE ONLY (Golden Rule 1).
# ============================================

# --- Google Gemini (aistudio.google.com → Get API key) ---
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# --- DeepSeek (platform.deepseek.com → API keys) — ADR-023 ---
# Serves rerank / extract_job / followup / skill_growth / forms. Its API is
# OpenAI-compatible, so the `openai` SDK drives it via DEEPSEEK_BASE_URL.
# Leave DEEPSEEK_API_KEY blank to run Gemini-only: every DeepSeek-routed task
# falls back to Gemini rather than failing (services/llm.py::_provider_for).
# Model names are explicit — the deepseek-chat / deepseek-reasoner aliases are
# deprecated 2026-07-24, so don't use them even though they still resolve.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Which provider generates tailored resume bullets. Stays "gemini" until
# guardrail-pass rates are measured on DeepSeek output — tailoring is the one
# task the anti-fabrication guardrail sits behind (ADR-023, Golden Rule 4).
TAILOR_PROVIDER=gemini

# --- Supabase (supabase.com → project → Settings → API) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # server-side key, bypasses RLS — guard it
SUPABASE_ANON_KEY=your-anon-key              # used by Flutter for auth only (Brick 9)

# --- Adzuna (developer.adzuna.com → register app) ---
ADZUNA_APP_ID=your-app-id
ADZUNA_APP_KEY=your-app-key
ADZUNA_COUNTRY=in                            # 'in' for India endpoints

# --- JSearch via RapidAPI (rapidapi.com → JSearch → subscribe Basic/free) ---
RAPIDAPI_KEY=your-rapidapi-key

# --- Apify (apify.com → Settings → Integrations) — scraped LinkedIn/Indeed/
# --- Naukri sources, ADR-003 (amended 2026-07-13) ---
# SET A SPEND CAP FIRST: Console → Settings → Billing → monthly usage limit.
# Apify actors bill per result/compute, unlike the free Adzuna/Greenhouse tiers,
# and a misconfigured query on an uncapped account can surprise you.
#
# Leave APIFY_API_TOKEN blank to run without any scraped sources — the fetchers
# log a warning and return nothing, and the daily pipeline carries on with
# Adzuna/JSearch/Greenhouse/Lever. Same posture as RESEND_API_KEY above.
APIFY_API_TOKEN=

# Actor IDs, format "owner~actor-name" — copy from the actor's page in the Apify
# store. These are config (not secrets) so that swapping a deprecated actor is an
# env change, not a code change. A blank ID skips that one source.
# Use NO-LOGIN actors only: we never hand LinkedIn/Indeed/Naukri account
# credentials to Apify, which is what carries the account-ban risk.
APIFY_LINKEDIN_ACTOR_ID=
APIFY_INDEED_ACTOR_ID=
APIFY_NAUKRI_ACTOR_ID=

# Per (role × location × source) result cap. Total Apify calls per daily run =
# roles × locations × 3 sources. Keep this low: it bounds your bill AND keeps
# the traffic pattern boring enough not to attract blocking.
APIFY_MAX_RESULTS_PER_QUERY=15

# --- Firebase Cloud Messaging (Brick 8; console.firebase.google.com) ---
# Path to the service-account JSON you download from Firebase project settings
FCM_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# --- Resend (resend.com → API Keys) — Phase 4 real follow-up sending ---
# Leave RESEND_API_KEY blank until you've signed up; "Approve & send" will
# 502 with a clear message instead of the server failing to start.
# RESEND_FROM_EMAIL defaults to Resend's sandbox address, which can only
# deliver to the email you signed up with until you verify your own domain
# (resend.com/docs/dashboard/domains/introduction).
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- App config ---
DAILY_PIPELINE_HOUR=7                        # local hour the agent runs

# These two lists FAN OUT into API calls on every refresh, so their sizes are a
# budget, not a wishlist (services/job_sources.py):
#   Adzuna  = roles × ADZUNA_LOCATIONS × 2   (each role queried twice: "<role>"
#             and "<role> intern" — Adzuna India has no internship filter)
#   JSearch = roles × TARGET_LOCATIONS       (capped at 200 requests/MONTH on
#             the free RapidAPI tier — with a daily cron that's ~6.5/day)
# Over the JSearch cap, its queries 429 and are logged+skipped, so the pipeline
# degrades quietly rather than failing: you just stop getting JSearch postings
# for the rest of the month. Adzuna/Greenhouse/Lever are unaffected.
# Don't list the same city twice under two names (bangalore AND bengaluru) —
# that doubles the calls for one place and the postings just get deduped anyway.
TARGET_ROLES=fullstack developer,frontend developer
TARGET_LOCATIONS=hyderabad,bangalore,remote

# Job source expansion Phase 1: optional wider Indian city list for Adzuna
# only (its free tier has far more headroom than JSearch's 200/month cap).
# Leave blank to fall back to TARGET_LOCATIONS. Set this — rather than widening
# TARGET_LOCATIONS — when you want more cities without paying JSearch quota for
# them, e.g. ADZUNA_LOCATIONS=hyderabad,bangalore,pune,chennai,remote
ADZUNA_LOCATIONS=
ENVIRONMENT=development                      # development | production

# --- Pipeline cron auth (Brick 9) ---
# Shared secret the Render cron job sends as X-Pipeline-Secret to trigger
# POST /pipeline/run (all-users batch). Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PIPELINE_SECRET=generate-your-own-random-secret

# --- Job freshness (Phase 1D) ---
# Postings older than this many days are skipped at ingestion.
MAX_JOB_AGE_DAYS=60

# --- Lite Gemini tier (ADR-017: JD-paste resume builder only) ---
# Defaults to gemini-3.1-flash-lite in config.py; override here if Google
# retires it (the old gemini-2.5-flash-lite now 404s for new API keys).
# GEMINI_MODEL_LITE=gemini-3.1-flash-lite
