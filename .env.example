# ============================================
# Job-Hunt Agent — environment template
# Copy to server/.env and fill in real values.
# NEVER commit .env — it's in .gitignore.
# All keys live SERVER-SIDE ONLY (Golden Rule 1).
# ============================================

# --- Google Gemini (aistudio.google.com → Get API key) ---
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

# --- Supabase (supabase.com → project → Settings → API) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # server-side key, bypasses RLS — guard it
SUPABASE_ANON_KEY=your-anon-key              # used by Flutter for auth only (Brick 9)

# --- Adzuna (developer.adzuna.com → register app) ---
ADZUNA_APP_ID=your-app-id
ADZUNA_APP_KEY=your-app-key
ADZUNA_COUNTRY=in                            # 'in' for India endpoints

# --- JSearch via RapidAPI (rapidapi.com → JSearch → subscribe Basic/free) ---
RAPIDAPI_KEY=your-rapidapi-key

# --- Firebase Cloud Messaging (Brick 8; console.firebase.google.com) ---
# Path to the service-account JSON you download from Firebase project settings
FCM_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# --- App config ---
DAILY_PIPELINE_HOUR=7                        # local hour the agent runs
TARGET_ROLES=flutter developer,python developer,mobile developer
TARGET_LOCATIONS=hyderabad,remote
ENVIRONMENT=development                      # development | production
